{
  "version": 2,
  "builds": [
    { "src": "api/cnv.js",     "use": "@vercel/node" },
    { "src": "api/express.js", "use": "@vercel/node" },
    { "src": "api/urgency.js", "use": "@vercel/node" },
    { "src": "index.html",     "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/cnv",     "dest": "/api/cnv.js" },
    { "src": "/api/express", "dest": "/api/express.js" },
    { "src": "/api/urgency", "dest": "/api/urgency.js" },
    { "src": "/(.*)",        "dest": "/index.html" }
  ]
}
