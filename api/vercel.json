{
  "version": 2,
  "builds": [
    {
      "src": "api/cnv.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/cnv",
      "dest": "/api/cnv.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
